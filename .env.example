RUST_MULE_API_URL=http://127.0.0.1:17835
RUST_MULE_API_PREFIX=/api/v1
RUST_MULE_LOG_PATH=/path/to/rust-mule.log
RUST_MULE_TOKEN_PATH=/path/to/api.token
RUST_MULE_DEBUG_TOKEN_FILE=/path/to/debug.token
RUST_MULE_SOURCE_PATH=/path/to/rust-mule/source

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
MATTERMOST_WEBHOOK_URL=

# 5 minutes
OBSERVE_INTERVAL_MS=300000

# Runtime persistence (defaults shown)
MULE_DOCTOR_DATA_DIR=/data/mule-doctor
MULE_DOCTOR_STATE_PATH=/data/mule-doctor/state.json
MULE_DOCTOR_HISTORY_PATH=/data/mule-doctor/history.json
MULE_DOCTOR_HISTORY_LIMIT=500
MULE_DOCTOR_LLM_LOG_DIR=/data/mule-doctor
MULE_DOCTOR_UI_ENABLED=false
MULE_DOCTOR_UI_AUTH_TOKEN=
MULE_DOCTOR_UI_HOST=127.0.0.1
MULE_DOCTOR_UI_PORT=18080
MULE_DOCTOR_UI_LOG_BUFFER_LINES=2000

# Optional cost model (per 1K tokens, USD)
OPENAI_INPUT_COST_PER_1K=0
OPENAI_OUTPUT_COST_PER_1K=0
