{
  "name": "mule-doctor",
  "version": "0.0.1",
  "description": "Observability agent for rust-mule nodes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-operator-console-assets.mjs",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test src/test/*.test.mjs",
    "check": "npm run typecheck && npm run lint && npm test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1"
  },
  "license": "MIT",
  "dependencies": {
    "openai": "^6.27.0"
  }
}
